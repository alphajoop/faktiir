{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "PORT",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "FRONTEND_URL",
    "NODE_ENV",
    "COOKIE_DOMAIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["prisma:generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "prisma:generate": {
      "dependsOn": []
    },
    "test": {
      "cache": false
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
